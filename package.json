{
  "name": "agent-switch",
  "version": "0.1.1",
  "description": "A command-line tool that lets you manage and switch between multiple agent accounts instantly, no more constant logins and logouts.",
  "license": "MIT",
  "bin": {
    "agent-switch": "bin/agent-switch.cjs"
  },
  "scripts": {
    "build": "cargo build --bin agent-switch",
    "link:dev": "node scripts/link-dev-bin.cjs",
    "unlink:dev": "node scripts/unlink-dev-bin.cjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "Cargo.toml",
    "Cargo.lock",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "cli",
    "auth",
    "accounts",
    "switch",
    "tokens"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sls0n/codex-account-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/Sls0n/codex-account-switcher/issues"
  },
  "homepage": "https://github.com/Sls0n/codex-account-switcher#readme",
  "author": "Sls0n"
}
