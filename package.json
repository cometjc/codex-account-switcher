{
  "name": "agent-switch",
  "version": "0.1.1",
  "description": "Rust TUI to manage, switch, and inspect multiple Codex accounts with built-in usage plots.",
  "license": "MIT",
  "bin": {
    "agent-switch": "bin/agent-switch.cjs"
  },
  "scripts": {
    "build": "cargo build --bin agent-switch",
    "test": "cargo test && node --test tests/entrypoints.test.js tests/plot-mode-shell.test.js tests/plot-readme.test.js tests/plot-rust-model-contract.test.js tests/plot-viewer-scaffold.test.js",
    "lint:rust": "cargo clippy --all-targets -- -D warnings",
    "audit:rust": "cargo audit",
    "check": "npm run lint:rust && npm test && npm run audit:rust",
    "pld:scoreboard:refresh": "node plugins/parallel-lane-dev/scripts/pld-refresh-scoreboard.cjs",
    "pld:probe": "node plugins/parallel-lane-dev/scripts/pld-probe-lane.cjs",
    "pld:envelope:record": "node plugins/parallel-lane-dev/scripts/pld-envelope.cjs",
    "pld:command:record": "node plugins/parallel-lane-dev/scripts/pld-record-command-event.cjs",
    "pld:reduce": "node plugins/parallel-lane-dev/scripts/pld-reduce-execution.cjs",
    "pld:state:record": "node plugins/parallel-lane-dev/scripts/pld-record-lane-state.cjs",
    "pld:insight:record": "node plugins/parallel-lane-dev/scripts/pld-record-insight.cjs",
    "pld:insights:summarize": "node plugins/parallel-lane-dev/scripts/pld-summarize-insights.cjs",
    "pld:active-set:replan": "node plugins/parallel-lane-dev/scripts/pld-replan-active-set.cjs",
    "pld:refill:suggest": "node plugins/parallel-lane-dev/scripts/pld-suggest-refill.cjs",
    "pld:schedule:suggest": "node plugins/parallel-lane-dev/scripts/pld-suggest-schedule.cjs",
    "pld:cycle": "node plugins/parallel-lane-dev/scripts/pld-run-cycle.cjs",
    "pld:launch": "node plugins/parallel-lane-dev/scripts/pld-launch-active-set.cjs",
    "pld:review": "node plugins/parallel-lane-dev/scripts/pld-drive-review-loop.cjs",
    "pld:intake": "node plugins/parallel-lane-dev/scripts/pld-intake-ready-to-commit.cjs",
    "pld:autopilot": "node plugins/parallel-lane-dev/scripts/pld-run-coordinator-loop.cjs",
    "pld:dispatch-plan": "node plugins/parallel-lane-dev/scripts/pld-build-dispatch-plan.cjs",
    "pld:compose": "node plugins/parallel-lane-dev/scripts/pld-compose-message.cjs",
    "pld:telemetry:summarize": "node plugins/parallel-lane-dev/scripts/pld-summarize-telemetry.cjs",
    "pld:telemetry:review": "node plugins/parallel-lane-dev/scripts/pld-render-telemetry-review.cjs",
    "pld:executor": "node plugins/parallel-lane-dev/scripts/pld-executor.cjs",
    "pld:executor:import": "node plugins/parallel-lane-dev/scripts/pld-executor.cjs import-plans",
    "pld:executor:audit": "node plugins/parallel-lane-dev/scripts/pld-executor.cjs audit",
    "pld:executor:go": "node plugins/parallel-lane-dev/scripts/pld-executor.cjs go",
    "link:dev": "node scripts/link-dev-bin.cjs",
    "unlink:dev": "node scripts/unlink-dev-bin.cjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "Cargo.toml",
    "Cargo.lock",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "cli",
    "auth",
    "accounts",
    "switch",
    "tokens",
    "tui",
    "ratatui",
    "plot"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sls0n/codex-account-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/Sls0n/codex-account-switcher/issues"
  },
  "homepage": "https://github.com/Sls0n/codex-account-switcher#readme",
  "author": "Sls0n"
}
