{
  "name": "codex-auth",
  "version": "0.1.1",
  "description": "A command-line tool that lets you manage and switch between multiple Codex accounts instantly, no more constant logins and logouts.",
  "license": "MIT",
  "bin": {
    "codex-auth": "bin/codex-auth.cjs"
  },
  "scripts": {
    "build": "cargo build --manifest-path rust/plot-viewer/Cargo.toml --bin codex-auth",
    "nlsdd:scoreboard:refresh": "node NLSDD/scripts/nlsdd-refresh-scoreboard.cjs",
    "nlsdd:probe": "node NLSDD/scripts/nlsdd-probe-lane.cjs",
    "nlsdd:envelope:record": "node NLSDD/scripts/nlsdd-envelope.cjs",
    "nlsdd:command:record": "node NLSDD/scripts/nlsdd-record-command-event.cjs",
    "nlsdd:reduce": "node NLSDD/scripts/nlsdd-reduce-execution.cjs",
    "nlsdd:state:record": "node NLSDD/scripts/nlsdd-record-lane-state.cjs",
    "nlsdd:insight:record": "node NLSDD/scripts/nlsdd-record-insight.cjs",
    "nlsdd:insights:summarize": "node NLSDD/scripts/nlsdd-summarize-insights.cjs",
    "nlsdd:active-set:replan": "node NLSDD/scripts/nlsdd-replan-active-set.cjs",
    "nlsdd:refill:suggest": "node NLSDD/scripts/nlsdd-suggest-refill.cjs",
    "nlsdd:schedule:suggest": "node NLSDD/scripts/nlsdd-suggest-schedule.cjs",
    "nlsdd:cycle": "node NLSDD/scripts/nlsdd-run-cycle.cjs",
    "nlsdd:launch": "node NLSDD/scripts/nlsdd-launch-active-set.cjs",
    "nlsdd:review": "node NLSDD/scripts/nlsdd-drive-review-loop.cjs",
    "nlsdd:intake": "node NLSDD/scripts/nlsdd-intake-ready-to-commit.cjs",
    "nlsdd:autopilot": "node NLSDD/scripts/nlsdd-run-coordinator-loop.cjs",
    "nlsdd:dispatch-plan": "node NLSDD/scripts/nlsdd-build-dispatch-plan.cjs",
    "nlsdd:compose": "node NLSDD/scripts/nlsdd-compose-message.cjs",
    "nlsdd:telemetry:summarize": "node NLSDD/scripts/nlsdd-summarize-telemetry.cjs",
    "nlsdd:telemetry:review": "node NLSDD/scripts/nlsdd-render-telemetry-review.cjs",
    "nlsdd:executor": "node NLSDD/scripts/nlsdd-executor.cjs",
    "nlsdd:executor:import": "node NLSDD/scripts/nlsdd-executor.cjs import-plans",
    "nlsdd:executor:audit": "node NLSDD/scripts/nlsdd-executor.cjs audit",
    "nlsdd:executor:go": "node NLSDD/scripts/nlsdd-executor.cjs go",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "rust/plot-viewer/Cargo.toml",
    "rust/plot-viewer/Cargo.lock",
    "rust/plot-viewer/src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "cli",
    "auth",
    "accounts",
    "switch",
    "tokens"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sls0n/codex-account-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/Sls0n/codex-account-switcher/issues"
  },
  "homepage": "https://github.com/Sls0n/codex-account-switcher#readme",
  "author": "Sls0n"
}
