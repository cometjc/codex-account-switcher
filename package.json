{
  "name": "codex-auth",
  "version": "0.1.1",
  "description": "A command-line tool that lets you manage and switch between multiple Codex accounts instantly, no more constant logins and logouts.",
  "license": "MIT",
  "bin": {
    "codex-auth": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "nlsdd:scoreboard:refresh": "node NLSDD/scripts/nlsdd-refresh-scoreboard.cjs",
    "nlsdd:probe": "node NLSDD/scripts/nlsdd-probe-lane.cjs",
    "nlsdd:state:record": "node NLSDD/scripts/nlsdd-record-lane-state.cjs",
    "nlsdd:insight:record": "node NLSDD/scripts/nlsdd-record-insight.cjs",
    "nlsdd:active-set:replan": "node NLSDD/scripts/nlsdd-replan-active-set.cjs",
    "nlsdd:refill:suggest": "node NLSDD/scripts/nlsdd-suggest-refill.cjs",
    "nlsdd:schedule:suggest": "node NLSDD/scripts/nlsdd-suggest-schedule.cjs",
    "nlsdd:cycle": "node NLSDD/scripts/nlsdd-run-cycle.cjs",
    "nlsdd:launch": "node NLSDD/scripts/nlsdd-launch-active-set.cjs",
    "nlsdd:compose": "node NLSDD/scripts/nlsdd-compose-message.cjs",
    "plot:viewer:build": "cargo build --manifest-path rust/plot-viewer/Cargo.toml",
    "plot:viewer:run": "cargo run --manifest-path rust/plot-viewer/Cargo.toml --",
    "link:dev": "node scripts/link-dev-bin.cjs",
    "unlink:dev": "node scripts/unlink-dev-bin.cjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "cli",
    "auth",
    "accounts",
    "switch",
    "tokens"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sls0n/codex-account-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/Sls0n/codex-account-switcher/issues"
  },
  "homepage": "https://github.com/Sls0n/codex-account-switcher#readme",
  "author": "Sls0n",
  "dependencies": {
    "@inquirer/confirm": "^6.0.10",
    "@inquirer/input": "^5.0.10",
    "@inquirer/select": "^5.1.2",
    "@oclif/core": "^3.27.0",
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.6.2",
    "figures": "^6.1.0",
    "inquirer-action-select": "^0.0.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "oclif": {
    "bin": "codex-auth",
    "commands": "./dist/commands"
  }
}
